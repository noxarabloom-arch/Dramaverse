# ─── Supabase ─────────────────────────────────────────────────────
# Copy these from your Supabase project → Settings → API
# Set the same values in Netlify: Site settings → Environment variables

SUPABASE_PROJECT_ID=your_project_id
SUPABASE_URL=https://your_project_id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_anon_key

# Also needed as VITE_ prefixed for client-side access
VITE_SUPABASE_PROJECT_ID=your_project_id
VITE_SUPABASE_URL=https://your_project_id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key

# Service role key — server-side only, NEVER expose to client
# Required for admin operations (e.g. src/integrations/supabase/client.server.ts)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
